        {
          "id": "55a8ce5d-29bd-4dff-b913-c760d4c98cd3",
          "name": "Vessel Route to Port",
          "request": {
            "name": "Vessel Route to Port",
            "description": {
              "content": "<b>A newer version of this endpoint is available here: https://developers.kpler.com/spec/c78f79cf-4169-4a59-987d-e5970ea170f9</b></br></br>\nReceive a list of available routes and distances from a vessel to a port.</br></br> <b>Notes</b> <ul>\n    <li>The <b>frequency of allowed API calls</b> is specific to your API key and is detailed in your contract as a number of successful calls per time period. For example “2 calls per minute”. </br>Regardless of this agreed limit, each API key is technically restricted to a maximum of 100 total (including successful and unsuccessful) requests per minute to ensure system stability.</li>\n</ul>",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "exportroutes",
                ":api_key"
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "mmsi",
                  "value": "<integer>",
                  "description": "(Required) The Maritime Mobile Service Identity (MMSI) of the vessel you wish to track </br></br> You can <b>instead</b> use imo or shipid"
                },
                {
                  "disabled": false,
                  "key": "imo",
                  "value": "<integer>",
                  "description": "The International Maritime Organization (IMO) number of the vessel you wish to track"
                },
                {
                  "disabled": false,
                  "key": "shipid",
                  "value": "<integer>",
                  "description": "A uniquely assigned ID by MarineTraffic for the subject vessel"
                },
                {
                  "disabled": false,
                  "key": "port_target_id",
                  "value": "<integer>",
                  "description": "(Required) The MarineTraffic ID of the port you wish to put as target port (found on the URL of the respective Port page) or port UN/LOCODE"
                },
                {
                  "disabled": false,
                  "key": "includealternatives",
                  "value": "<integer>",
                  "description": "Use 1 to search for all available routes regarding the specific journey or 0 to not include alternative routes"
                },
                {
                  "disabled": false,
                  "key": "includeinland",
                  "value": "<integer>",
                  "description": "Use 1 in order to receive routes which include inland waterways or 0 to not include alternative routes"
                },
                {
                  "disabled": false,
                  "key": "msgtype",
                  "value": "simple",
                  "description": "Resolution of the response. Available values: <ul>\n  <li>simple</li>\n  <li>extended</li>\n</ul> If used with the value <b>extended</b>, the response includes also route/waypoints as Linestring Geometry in WKT - Well-Known Text"
                },
                {
                  "disabled": false,
                  "key": "protocol",
                  "value": "xml",
                  "description": "Response type. Use one of the following: <ul>\n  <li>xml</li>\n  <li>csv</li>\n  <li>json</li>\n  <li>jsono</li>"
                }
              ],
              "variable": [
                {
                  "disabled": false,
                  "type": "any",
                  "value": "<string>",
                  "key": "api_key",
                  "description": "(Required) API key: 40-character hexadecimal number"
                }
              ]
            },
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "GET",
            "auth": null
          },
